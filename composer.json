{
    "name": "rivium-trace/laravel-sdk",
    "description": "RiviumTrace Laravel SDK for error tracking, logging, and performance monitoring",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "error-tracking",
        "monitoring",
        "observability",
        "logging",
        "apm",
        "performance",
        "rivium-trace"
    ],
    "authors": [
        {
            "name": "RiviumTrace Team",
            "email": "support@rivium.co",
            "homepage": "https://rivium.co"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "RiviumTrace\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RiviumTrace\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RiviumTrace\\Laravel\\RiviumTraceServiceProvider"
            ],
            "aliases": {
                "RiviumTrace": "RiviumTrace\\Laravel\\RiviumTraceFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
